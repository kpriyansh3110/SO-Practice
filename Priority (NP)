#include <stdio.h>

int main() {

    int n;
    int at[20], bt[20], pr[20];
    int wt[20], tat[20], rt[20], ct[20];
    int completed = 0, time = 0, min_pr, index;

    float avg_wt = 0, avg_tat = 0, avg_rt = 0;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(int i=0;i<n;i++){
        printf("Enter AT BT Priority for P%d: ",i+1);
        scanf("%d %d %d",&at[i],&bt[i],&pr[i]);
    }

    int done[20] = {0};

    while(completed < n){

        min_pr = 9999;
        index = -1;

        for(int i=0;i<n;i++){
            if(at[i] <= time && done[i]==0){
                if(pr[i] < min_pr){
                    min_pr = pr[i];
                    index = i;
                }
            }
        }

        if(index == -1){
            time++;
        }
        else{
            rt[index] = time - at[index];

            time += bt[index];
            ct[index] = time;

            tat[index] = ct[index] - at[index];
            wt[index] = tat[index] - bt[index];

            avg_wt += wt[index];
            avg_tat += tat[index];
            avg_rt += rt[index];

            done[index] = 1;
            completed++;
        }
    }

    printf("\nPID\tAT\tBT\tPR\tWT\tTAT\tRT\n");

    for(int i=0;i<n;i++){
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
        i+1,at[i],bt[i],pr[i],wt[i],tat[i],rt[i]);
    }

    printf("\nAverage WT = %.2f",avg_wt/n);
    printf("\nAverage TAT = %.2f",avg_tat/n);
    printf("\nAverage RT = %.2f\n",avg_rt/n);

    return 0;
}
