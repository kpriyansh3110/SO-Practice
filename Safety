#include <stdio.h>

int main()
{
    int p, r, i, j, k;

 
    printf("Enter number of processes: ");
    scanf("%d", &p);

    printf("Enter number of resource types: ");
    scanf("%d", &r);

    int allocation[p][r];
    int maximum[p][r];
    int need[p][r];
    int available[r];


    printf("\nEnter Allocation Matrix:\n");
    for(i = 0; i < p; i++)
    {
        for(j = 0; j < r; j++)
        {
            scanf("%d", &allocation[i][j]);
        }
    }

    printf("\nEnter Maximum Matrix:\n");
    for(i = 0; i < p; i++)
    {
        for(j = 0; j < r; j++)
        {
            scanf("%d", &maximum[i][j]);
        }
    }

    printf("\nEnter Available Resources:\n");
    for(i = 0; i < r; i++)
    {
        scanf("%d", &available[i]);
    }

  
    for(i = 0; i < p; i++)
    {
        for(j = 0; j < r; j++)
        {
            need[i][j] = maximum[i][j] - allocation[i][j];
        }
    }

 
    printf("\nNeed Matrix:\n");
    for(i = 0; i < p; i++)
    {
        for(j = 0; j < r; j++)
        {
            printf("%d ", need[i][j]);
        }                                                  
        printf("\n");
    }

    int finish[p];
    int safeSequence[p];
    int work[r];
    int count = 0;

  
    for(i = 0; i < p; i++)
    {
        finish[i] = 0;
    }

 
    for(i = 0; i < r; i++)
    {
        work[i] = available[i];
    }

    while(count < p)
    {
        int found = 0;

        for(i = 0; i < p; i++)
        {
            if(finish[i] == 0)
            {
                for(j = 0; j < r; j++)
                {
                    if(need[i][j] > work[j])
                    {
                        break;
                    }
                }


                if(j == r)
                {
                    for(k = 0; k < r; k++)
                    {
                        work[k] += allocation[i][k];
                    }

                    safeSequence[count] = i;
                    count++;
                    finish[i] = 1;
                    found = 1;
                }
            }
        }


        if(found == 0)
        {
            printf("\nSystem is NOT in Safe State\n");
            return 0;
        }
    }


    printf("\nSystem is in SAFE State\n");
    printf("Safe Sequence:\n");

    for(i = 0; i < p; i++)
    {
        printf("P%d", safeSequence[i]);

        if(i != p - 1)
        {
            printf(" -> ");
        }
    }

    printf("\n");

    return 0;
}
