#include <stdio.h>
#include <limits.h>

int main(){

    int n;
    int at[20], bt[20], pr[20];
    int rt[20], wt[20], tat[20], response[20];
    int first[20] = {0};

    int time = 0, completed = 0;

    float avg_wt = 0, avg_tat = 0, avg_rt = 0;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(int i=0;i<n;i++){
        printf("Enter AT BT Priority for P%d: ",i+1);
        scanf("%d %d %d",&at[i],&bt[i],&pr[i]);

        rt[i] = bt[i];
    }

    while(completed < n){

        int min_pr = INT_MAX;
        int index = -1;

        for(int i=0;i<n;i++){
            if(at[i] <= time && rt[i] > 0){
                if(pr[i] < min_pr){
                    min_pr = pr[i];
                    index = i;
                }
            }
        }

        if(index == -1){
            time++;
            continue;
        }

        if(first[index] == 0){
            response[index] = time - at[index];
            first[index] = 1;
        }

        rt[index]--;
        time++;

        if(rt[index] == 0){

            completed++;

            tat[index] = time - at[index];
            wt[index] = tat[index] - bt[index];

            avg_wt += wt[index];
            avg_tat += tat[index];
            avg_rt += response[index];
        }
    }

    printf("\nPID\tAT\tBT\tPR\tWT\tTAT\tRT\n");

    for(int i=0;i<n;i++){
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
        i+1,at[i],bt[i],pr[i],wt[i],tat[i],response[i]);
    }

    printf("\nAverage WT = %.2f",avg_wt/n);
    printf("\nAverage TAT = %.2f",avg_tat/n);
    printf("\nAverage RT = %.2f\n",avg_rt/n);

    return 0;
}
